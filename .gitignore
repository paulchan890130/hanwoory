# version-independent human-review decision store (runtime/persistent, row_id keyed)
backend/data/manuals/manual_review_decisions.json
# rhwp auto-staging runtime state + lock (per-instance, persistent on disk)
backend/data/manuals/manual_auto_update_state.json
backend/data/manuals/.manual_auto_update.lock
