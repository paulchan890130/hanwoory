  "tb_certificate_rules": {
    "rule_category": "health",
    "title": "외국인 결핵진단서 제출 의무 관련 안내",
    "source": "260310 체류민원 매뉴얼 p.5-6, 260310 사증민원 매뉴얼 p.5-6, 221230 편람 p.12-13",
    "submission_cases": {
      "visa_application": [
        {
          "case": "국내 90일 초과 체류 목적 사증 신청",
          "detail": "전자사증 대상자의 경우 국내 입국 후 외국인등록 시 제출",
          "legal_basis": "출입국관리법 제10조의2 제1항 제2호(장기체류자격) - 체류기간이 90일 이하라도 장기체류자격 사증을 신청하는 경우 결핵진단서 제출 대상"
        },
        {
          "case": "단기체류자격 중 계절근로자(C-4-1~4) 및 국내 체류 중인 외국인 결핵환자가 가족 등을 간병인으로 초청하는 경우",
          "detail": null
        },
        {
          "case": "과거 결핵진단서를 제출하고 국내에 장기체류하다가 완전출국 후 새로운 장기체류사증을 발급받으려는 경우",
          "detail": null
        }
      ],
      "alien_registration": [
        {
          "case": "사증 신청 시 결핵진단서를 제출해야 하는 외국인이 전자사증으로 입국한 경우",
          "detail": null
        },
        {
          "case": "결핵고위험국가 국민이 장기체류 가능한 복수사증을 소지하고 사증 발급일로부터 6개월이 지나서 입국한 경우",
          "detail": null
        }
      ],
      "stay_permit_application": [
        {
          "case": "단기체류자격으로 입국한 결핵고위험국가 국민이 장기체류자격으로 변경 신청하는 경우",
          "detail": null
        },
        {
          "case": "장기체류자격으로 체류 중인 결핵고위험국가 국민 중 2016.3.2. 이후 사증 및 체류허가 신청 시 결핵진단서를 제출한 적이 없는 경우",
          "detail": null
        },
        {
          "case": "결핵고위험국가 국적의 등록외국인이 체류기간 연장 또는 체류자격변경 신청 시, 신청일 기준 1년 이내 연속으로 6개월 이상 결핵고위험국가에서 장기체류한 경우",
          "detail": "출국 행선지가 결핵 고위험국가가 아닌 경우 결핵진단서 제출 대상 아님. 출국행선지 확인이 불가한 경우 결핵진단서 제출을 원칙으로 하되 본인이 결핵 고위험 국가를 방문하지 않았음을 소명하는 경우 제출 면제 가능"
        }
      ]
    },
